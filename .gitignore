# Python cache / bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment files
.env
.env.*

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Tool caches and reports
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE / OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs and local databases
*.log
*.db
*.sqlite
*.sqlite3
*.duckdb

# Project data artifacts (generated/intermediate)
data/processed/
old_data/processed/

# Keep source/final datasets versionable by default
!data/raw/
!old_data/final/